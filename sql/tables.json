				"options": {
					"length": 65535,
					"notnull": false
				}
			},
			{
				"name": "ppv_props",
				"comment": "JSON blob of package properties",
				"type": "blob",
				"options": {
					"length": 16777215,
					"notnull": true
				}
			}
		],
		"indexes": [
			{
				"name": "ppv_package_version",
				"columns": [ "ppv_package", "ppv_version" ],
				"comment": "To deduplicate fetch requests",
				"unique": true
			}
		],
		"pk": [ "ppv_id" ]
	},
