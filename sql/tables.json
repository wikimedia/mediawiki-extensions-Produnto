	{
		"name": "produnto_package_version",
		"comment": "Package versions",
		"columns": [
			{
				"name": "ppv_id",
				"comment": "primary key",
				"type": "integer",
				"options": {
					"unsigned": true,
					"notnull": true,
					"autoincrement": true
				}
			},
			{
				"name": "ppv_package",
				"comment": "Link to produnto_package.pp_id",
				"type": "binary",
				"options": {
					"length": 255,
					"notnull": true
				}
			},
			{
				"name": "ppv_version",
				"comment": "The version string, e.g. 1.0.0",
