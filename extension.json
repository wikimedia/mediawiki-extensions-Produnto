{
	"name": "Produnto",
	"author": [
		"Tim Starling"
	],
	"url": "https://www.mediawiki.org/wiki/Special:MyLanguage/Extension:Produnto",
	"descriptionmsg": "produnto-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.45.0"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\Produnto\\": "src/"
	},
	"TestAutoloadNamespaces": {
		"MediaWiki\\Extension\\Produnto\\Tests\\": "tests/phpunit/"
	},
	"config": {
		"ProduntoServers": {
			"value": [],
			"description": "An array of server configuration objects describing upstream package sources"
		},
		"ProduntoPackagesTitle": {
			"value": null,
			"description": "The title to use for the deployed package list, or null for MediaWiki:Packages.json"
		}
	},
	"Hooks": {
		"LoadExtensionSchemaUpdates": "schema",
		"ContentHandlerDefaultModelFor": "updater",
		"JsonValidateSave": "updater",
		"PageSaveComplete": "updater"
	},
	"HookHandlers": {
		"schema": {
			"class": "MediaWiki\\Extension\\Produnto\\SchemaHooks"
		},
		"updater": {
			"class": "MediaWiki\\Extension\\Produnto\\Updater\\UpdaterHooks",
			"services": [
				"MainConfig",
				"TitleParser",
				"Produnto.Updater"
			]
		}
	},
	"DatabaseVirtualDomains": [
		"virtual-produnto"
	],
	"RestRoutes": [
		{
			"method": "POST",
			"path": "/produnto/v1/gitlab/tag",
			"class": "MediaWiki\\Extension\\Produnto\\Rest\\GitlabTagHandler",
			"services": [
				"Produnto.ServerContainer",
				"Produnto.Fetcher",
				"Produnto.Logger"
			]
		},
		{
			"method": "GET",
			"path": "/produnto/v1/sandbox",
			"class": "MediaWiki\\Extension\\Produnto\\Rest\\SandboxListHandler",
			"services": [
				"Produnto.SandboxStore"
			]
		},
		{
			"method": "POST",
			"path": "/produnto/v1/sandbox/{id}",
			"class": "MediaWiki\\Extension\\Produnto\\Rest\\SandboxPostHandler",
			"services": [
				"Produnto.Store",
				"Produnto.SandboxStore",
				"Produnto.ManifestFactory"
			]
		},
		{
			"method": "DELETE",
			"path": "/produnto/v1/sandbox/{id}",
			"class": "MediaWiki\\Extension\\Produnto\\Rest\\SandboxDeleteHandler",
			"services": [
				"Produnto.SandboxStore"
			]
		},
		{
			"method": "POST",
			"path": "/produnto/v1/sandbox/{id}/activate",
			"class": "MediaWiki\\Extension\\Produnto\\Rest\\SandboxActivateHandler",
			"services": [
				"Produnto.SandboxStore"
			]
		},
		{
			"method": "POST",
			"path": "/produnto/v1/sandbox/{id}/deactivate",
			"class": "MediaWiki\\Extension\\Produnto\\Rest\\SandboxDeactivateHandler"
		}
	],
	"SpecialPages": {
		"ProduntoSandbox": "MediaWiki\\Extension\\Produnto\\Sandbox\\ProduntoSandboxPage"
	},
	"JobClasses": {
		"ProduntoFetch": {
			"class": "MediaWiki\\Extension\\Produnto\\Fetcher\\FetchJob",
			"services": [
				"Produnto.Fetcher"
			],
			"needsPage": false
		}
	},
	"MessagesDirs": {
		"Produnto": [
			"i18n"
		]
	},
	"ExtensionMessagesFiles": {
		"ProduntoAlias": "Produnto.alias.php"
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "Produnto/resources"
	},
	"ResourceModules": {
		"ext.produnto.SpecialProduntoSandbox": {
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"dependencies": [
				"mediawiki.DateFormatter",
				"vue"
			],
			"messages": [
				"produnto-sandbox-activate",
				"produnto-sandbox-deactivate",
				"produnto-sandbox-active",
				"produnto-sandbox-inactive",
				"produnto-sandbox-empty",
				"produnto-sandbox-delete",
				"produnto-sandbox-size-kb",
				"produnto-sandbox-mtime",
				"produnto-sandbox-loading",
				"produnto-sandbox-notify-login"
			],
			"localBasePath": "resources/ext.produnto.SpecialProduntoSandbox",
			"remoteExtPath": "Produnto/resources/ext.produnto.SpecialProduntoSandbox",
			"packageFiles": [
				"init.js",
				"App.vue"
			],
			"codexComponents": [
				"CdxButton",
				"CdxMessage",
				"CdxProgressIndicator",
				"CdxToastContainer",
				"useToast"
			]
		}
	},
	"ServiceWiringFiles": [
		"src/ServiceWiring.php"
	],
	"manifest_version": 2
}
